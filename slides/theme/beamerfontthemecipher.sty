\ProvidesPackage{theme/beamerfontthemecipher}[2025/05/04 v1.0 Cipher Beamer Theme]

\setsansfont{Fira Sans}[Scale=1.0]
\setmonofont{JetBrains Mono}[Scale=0.9]
\setromanfont{STIX Two Text}[Scale=1.0]
\setmathfont{STIX Two Math}[Scale=1.0]

% Default font is sans-serif (Fira Sans)
\renewcommand{\familydefault}{\sfdefault}

% Slightly increase line spacing throughout the presentation
\linespread{1.05}\selectfont

% Frame title fonts
\setbeamerfont{frametitle}{family=\ttfamily, size=\LARGE, series=\bfseries}
\setbeamerfont{framesubtitle}{family=\ttfamily, size=\Large, series=\mdseries}

% Caption fonts
\setbeamerfont{caption}{family=\sffamily, size=\tiny}

% Footline fonts
\setbeamerfont{footline}{family=\ttfamily, size=\tiny}

% Cover slide specific fonts
\setbeamerfont{cover title}{family=\ttfamily, size=\LARGE}
\setbeamerfont{cover subtitle}{family=\ttfamily, size=\Large}
\setbeamerfont{part name}{family=\ttfamily, size=\scriptsize}
\setbeamerfont{session name}{family=\ttfamily, size=\large}
\setbeamerfont{cover author}{family=\ttfamily, size=\small}
\setbeamerfont{cover institute}{family=\ttfamily, size=\small}
