\ProvidesPackage{theme/beamerthemecipher}[2025/05/04 v1.0 Cipher Beamer Theme]

% Load required packages
\RequirePackage{tikz}
\RequirePackage[table]{xcolor}
\RequirePackage[most]{tcolorbox}
\RequirePackage{
	listings,svg,mathtools,fontspec,unicode-math,tcolorbox,
	amsmath,amsthm,amssymb,amsfonts,graphicx,setspace,
	etoolbox,hyperref,xstring,fancybox,varwidth,xspace,titlecaps
}
\RequirePackage[lining]{InriaSans}
\RequirePackage{microtype}
\RequirePackage[auto,outline]{contour}

% TikZ libraries
\usetikzlibrary{shadows, arrows.meta, positioning, shapes, calc, fit, shapes.geometric}

% Load dependent themes
\usecolortheme{cipher}
\usefonttheme{cipher}
\useinnertheme{cipher}
\useoutertheme{cipher}

% Custom commands
\newcommand{\coversessionname}[1]{\def\insertcoversessionname{#1}}
\newcommand{\coverpartname}[1]{\def\insertcoverpartname{#1}}

% Custom definition box
\newcommand{\definitionbox}[2]{%
  \begin{tcolorbox}[colback=ciphergray!40!white,colframe=cipherprimary,title=#1,fonttitle=\bfseries]
    #2
  \end{tcolorbox}
}

% Code listing box with syntax highlighting
\newcommand{\codebox}[3]{%
  \begin{tcolorbox}[enhanced,title=#1,
    colback=black!3!white,colframe=cipherprimary!70!black,
    colbacktitle=cipherprimary,coltitle=white,
    fonttitle=\bfseries\ttfamily\small,
    listing only,listing options={language=#2}]
    #3
  \end{tcolorbox}
}

% Nicely formatted image with caption
\newcommand{\imagewithcaption}[3][0.9\textwidth]{
	\begin{center}
		\begin{tikzpicture}
			\hspace{-1mm}
			\node[fill=white, anchor=center, inner sep=1mm]{
				\IfEndWith{#2}{.svg}
					{\includesvg[width=#1, height=0.9\textheight, keepaspectratio]{images/#2}}
					{\includegraphics[width=#1, height=0.9\textheight, keepaspectratio]{images/#2}}
			};
			\node[fit=(current bounding box), inner sep=0.5mm, draw=white, line width=0.5mm] {};
		\end{tikzpicture}
		\vspace{0.5em}
		\begin{minipage}{0.7\textwidth}
				\centering
				\usebeamerfont{caption}#3
		\end{minipage}
	\end{center}
}

% Nicely formatted image with caption (big)
\newcommand{\bigimagewithcaption}[3][1\textwidth]{
	\begin{center}
		\vspace{-0.75cm}
		\begin{tikzpicture}
			\hspace{-1mm}
			\node[fill=white, anchor=center, inner sep=1mm]{
				\IfEndWith{#2}{.svg}
					{\includesvg[width=#1, height=0.8\textheight, keepaspectratio]{images/#2}}
					{\includegraphics[width=#1, height=0.8\textheight, keepaspectratio]{images/#2}}
			};
			\node[fit=(current bounding box), inner sep=0.5mm, draw=white, line width=0.5mm] {};
		\end{tikzpicture}
		\vspace{0.3em}
		\begin{minipage}{0.8\textwidth}
			\centering
			\usebeamerfont{caption}#3
		\end{minipage}
	\end{center}
}

% Macro for state-separable proof style subroutines
\newcommand{\sssubroutine}[4]{
	\begin{center}
		\begin{tikzpicture}[box/.style={rectangle, draw, align=left, fill=white, inner sep=7pt, scale=#4, execute at begin node=\setlength{\baselineskip}{1.5em}}]
			\node[box]{
				\underline{\ensuremath{\textsf{\upshape#1}}\scalebox{1.1}{$(#2)$}}: \\
				#3
			};
		\end{tikzpicture}
	\end{center}
}

\newcommand{\sslibrarysubroutine}[4]{
	\begin{tikzpicture}[box/.style={rectangle, align=left, inner sep=0pt, outer sep=0pt, fill=white, scale=#4, execute at begin node=\setlength{\baselineskip}{1.5em}, inner sep=0pt, outer sep=0pt}]
		\node[box]{
			\underline{\sslibraryfun{#1}{#2}}: \\
			#3
		};
	\end{tikzpicture}
}

\newcommand{\nliteral}[1]{\textcolor{ciphernliteral}{\texttt{#1}}}
\newcommand{\prob}[1]{\ensuremath{\Pr\bigl[\ensuremath{#1}\bigr]}}
\newcommand{\lib}[2]{\ensuremath{\mathcal{L}^{#1}_\text{#2}}}
\newcommand{\prog}[1]{\ensuremath{\mathcal{A}_\text{#1}}}
\newcommand{\link}{\ensuremath{\diamond}}
\newcommand{\interchangeable}[1]{\ensuremath{\overset{\ensuremath{#1}}{\equiv}}}
\newcommand{\bits}{\ensuremath{\{\nliteral{0}, \nliteral{1}\}}}
\newcommand{\sslibraryfun}[2]{\ensuremath{\textrm{\textsc{\lowercase{#1}}}\scalebox{1.1}{\ensuremath{(#2)}}}}

\newtcolorbox{sslibrarybox}[2][]{
	colback=white,
	colframe=black,
	colbacktitle=sstitlecolor,
	coltitle=black,
	enhanced,hbox,
	toptitle=1mm,
	bottomtitle=1mm,
	boxrule=0.5pt,
	titlerule=0pt,
	left=1mm,
	right=1mm,
	top=2mm,
	bottom=2mm,
	titlerule style=sstitlecolor,
	sharp corners,
	halign title=center,
	title={#2},
	#1
}

\newcommand{\sslibrary}[4]{
	\begin{sslibrarybox}[scale=#4]{\lib{#1}{#2}}
		\begin{varwidth}{\pagewidth}
			#3
		\end{varwidth}
	\end{sslibrarybox}
}

\newcommand{\ssprogram}[3]{
	\begin{sslibrarybox}[scale=#3]{\prog{#1}}
		\begin{tikzpicture}[box/.style={rectangle, align=left, fill=white, inner sep=0pt, outer sep=0pt, execute at begin node=\setlength{\baselineskip}{1.5em}}]
			\node[box]{
				#2
			};
		\end{tikzpicture}
	\end{sslibrarybox}
}

\newcommand{\sslinked}[3]{
	\begin{tikzpicture}[baseline]
		\node[inner sep=0pt, outer sep=0pt] (left) {\begin{varwidth}{\textwidth}#1\end{varwidth}};
		\node[inner sep=0pt, outer sep=0pt, anchor=west] (middle) at (left.east) {\begin{varwidth}{\textwidth}{\Large\ensuremath{\ #2\ }}\end{varwidth}};
		\node[inner sep=0pt, outer sep=0pt, anchor=west] (right) at (middle.east) {\begin{varwidth}{\textwidth}#3\end{varwidth}};
	\end{tikzpicture}
}

\contourlength{1.2pt}
\newcommand{\hl}[1]{%
    \relax\ifmmode%
        {}%
        \contour{hlbg}{\textcolor{hlfg}{${} #1 {}$}}%
        {}%
    \else%
        \contour{hlbg}{\textcolor{hlfg}{#1}}%
    \fi%
}
