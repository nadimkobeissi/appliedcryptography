\ProvidesPackage{beamerinnerthemecipher}[2025/05/04 v1.0 Cipher Beamer Theme]

% Cover slide (title page with logo and image)
\defbeamertemplate*{title page}{cipher}{
  % Background
  \begin{tikzpicture}[remember picture, overlay]
    \fill[cipherdarkbg] (current page.north west) rectangle (current page.south east);
    \draw[cipheraccent, line width=3pt]
      (current page.north west) rectangle (current page.south east);
  \end{tikzpicture}

  % University logo
  \begin{tikzpicture}[remember picture, overlay]
    \node[anchor=north west, inner sep=0pt] at ([shift={(0.95cm,-0.4cm)}]current page.north west) {
      \includegraphics[height=1.6cm]{images/aub_white.png}
    };
  \end{tikzpicture}

  % Grid layout for cover slide
  \vspace{1cm}
  \begin{columns}[c,onlytextwidth]
    % Left column - image
    \begin{column}{0.42\textwidth}
      \begin{beamercolorbox}[center]{cover text}
        \begin{tikzpicture}
          \node[inner sep=0pt] {
            \includegraphics[width=\textwidth, height=1\textwidth, keepaspectratio]{images/cedar.jpg}
          };
          \draw[white, line width=1mm]
            (current bounding box.south west) rectangle (current bounding box.north east);
        \end{tikzpicture}
      \end{beamercolorbox}
    \end{column}

    % Right column - text
    \begin{column}{0.6\textwidth}
      \begin{beamercolorbox}[wd=\textwidth, leftskip=1.3cm]{cover title}
        \usebeamerfont{cover title}\usebeamercolor[fg]{cover title}Applied Cryptography\par
        \vskip0cm
        \usebeamercolor[fg]{cover subtitle}\usebeamerfont{cover subtitle}CMPS 297AD/396AI\par
        \vskip0.5cm
        \usebeamercolor[fg]{part name}\usebeamerfont{part name}\insertcoverpartname\par
        \vskip0cm
        \usebeamercolor[fg]{session name}\usebeamerfont{session name}\insertcoversessionname\par
        \vskip0.5cm
        \usebeamercolor[fg]{cover author}\usebeamerfont{cover author}Nadim Kobeissi\par
        \vskip0.1cm
        \usebeamercolor[fg]{cover author}\usebeamerfont{cover institute}\small{\url{https://appliedcryptography.page}}\par
      \end{beamercolorbox}
    \end{column}
  \end{columns}
}

% Items
\setbeamertemplate{itemize item}{\small\raise0.5pt\hbox{\donotcoloroutermaths$\bullet$}}
\setbeamertemplate{itemize subitem}{\small\raise0.5pt\hbox{\donotcoloroutermaths$\circ$}}
\setbeamertemplate{itemize subsubitem}{\small\raise0.5pt\hbox{\donotcoloroutermaths$\diamond$}}

% Blocks
\setbeamertemplate{block begin}{
  \par\vskip\medskipamount
  \begin{beamercolorbox}[rounded=true,colsep*=0.75ex]{block title}
    \usebeamerfont{block title}\insertblocktitle
  \end{beamercolorbox}
  \begin{beamercolorbox}[rounded=true,colsep*=0.75ex,sep=0.5ex,vmode]{block body}
    \usebeamerfont{block body}
    \ifbeamercolorempty[bg]{block body}{\vskip-.25ex}{}%
}
\setbeamertemplate{block end}{
  \end{beamercolorbox}
  \vskip\smallskipamount
}

% Alerted blocks
\setbeamertemplate{block alerted begin}{
  \par\vskip\medskipamount
  \begin{beamercolorbox}[rounded=true,colsep*=0.75ex]{block title alerted}
    \usebeamerfont{block title alerted}\insertblocktitle
  \end{beamercolorbox}
  \begin{beamercolorbox}[rounded=true,colsep*=0.75ex,sep=0.5ex,vmode]{block body alerted}
    \usebeamerfont{block body alerted}
    \ifbeamercolorempty[bg]{block body alerted}{\vskip-.25ex}{}%
}
\setbeamertemplate{block alerted end}{
  \end{beamercolorbox}
  \vskip\smallskipamount
}

% Example blocks
\setbeamertemplate{block example begin}{
  \par\vskip\medskipamount
  \begin{beamercolorbox}[rounded=true,colsep*=0.75ex]{block title example}
    \usebeamerfont{block title example}\insertblocktitle
  \end{beamercolorbox}
  \begin{beamercolorbox}[rounded=true,colsep*=0.75ex,sep=0.5ex,vmode]{block body example}
    \usebeamerfont{block body example}
    \ifbeamercolorempty[bg]{block body example}{\vskip-.25ex}{}%
}
\setbeamertemplate{block example end}{
  \end{beamercolorbox}
  \vskip\smallskipamount
}

\newcommand{\imagewithcaption}[3][0.9\textwidth]{
	\begin{center}
		\begin{tikzpicture}
			\node[inner sep=1mm]
				{ \includegraphics[width=#1, keepaspectratio]{images/#2} };
			\draw[white, line width=1mm]
				(current bounding box.south west) rectangle (current bounding box.north east);
		\end{tikzpicture}
		\vspace{0.5em}
		\begin{minipage}{0.7\textwidth}
				\centering
				\usebeamerfont{caption}#3
		\end{minipage}
	\end{center}
}

% Image with caption template
\newcommand{\bigimagewithcaption}[3][1\textwidth]{
	\begin{center}
		\vspace{-0.6cm}
		\begin{tikzpicture}
			\node[inner sep=1mm]
				{ \includegraphics[width=#1, height=0.8\textheight, keepaspectratio]{images/#2} };
			\draw[white, line width=1mm]
				(current bounding box.south west) rectangle (current bounding box.north east);
		\end{tikzpicture}
		\vspace{0.3em}
		\begin{minipage}{0.8\textwidth}
			\centering
			\usebeamerfont{caption}#3
		\end{minipage}
	\end{center}
}
